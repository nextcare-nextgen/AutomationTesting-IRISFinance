{
  "name": "pulse-playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "Tests": "npx playwright test",
    "smoke": "npx playwright test --grep \"@smoke\"",
    "sanity": "npx playwright test --grep \"@sanity\"",
    "regression": "npx playwright test --grep-invert \"@smoke|@sanity\"",
    "zip-report": "powershell -NoProfile -Command \"if (Test-Path 'playwright-report.zip') { Remove-Item 'playwright-report.zip' -Force }; if (Test-Path 'playwright-report') { Compress-Archive -Path 'playwright-report\\*' -DestinationPath 'playwright-report.zip' -Force }\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/node": "^20.10.7",
    "allure-playwright": "^2.3.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "xlsx": "^0.18.5"
  }
}
